# Rendered by the IaC layer's compose_project ansible role.
#
# Tracked in the repo so docker's bind mount in docker-compose.prod.yml
# (`./docker/nginx/.htpasswd.example:/etc/nginx/.htpasswd:ro`) finds a
# regular file on a fresh checkout. Without this stub, docker auto-creates
# a *directory* at the source path; ansible's subsequent write of the real
# htpasswd content would then fail (cannot write a file where a directory
# exists), and any nginx location using `auth_basic_user_file` would try
# to open a directory and silently disable auth.
